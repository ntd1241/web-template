# Sao chép thành .env.local và chỉnh theo môi trường. KHÔNG commit .env.local.

# REST API base URL (khi có backend thật)
VITE_API_URL=http://localhost:3000/api/v1

# Bật mock data (mock-first). '1' = dùng mock, '0' = gọi API thật.
VITE_USE_MOCK=1

# Hiển thị
VITE_APP_NAME=Admin Template
VITE_DEFAULT_LOCALE=vi
